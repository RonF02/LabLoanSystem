{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build LabLoanSystem",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd /d \"${workspaceFolder}\" && C:\\msys64\\ucrt64\\bin\\gcc.exe -g -Iinclude src\\*.c -o build\\LabLoanSystem.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Run LabLoanSystem (UTF-8)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd /d \"${workspaceFolder}\\build\" && chcp 65001>nul && .\\LabLoanSystem.exe"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}